// https://www.reactnativeschool.com/how-to-setup-path-alias-in-a-react-native-typescript-app
{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": "./app",
    // "rootDir": "app",
    "strict": true,
    "paths": {
      // This needs to be mirrored in babel.config.js
      // Components is a directory with sub directories
      "@screens/*": ["./boundedContext/presentation/screens/*"],
      "@navigations/*": ["./boundedContext/presentation/navigations/*"],
      "@hooks/*": ["./boundedContext/application/hooks/*"],
      "@domain/*": ["./boundedContext/domain/*"],
      "@infrastructure/*": ["./boundedContext/infrastructure/*"],
      "@storage/*": ["./boundedContext/infrastructure/storage/*"],
      "@repositories/*": ["./boundedContext/infrastructure/repositories/*"],
      "@components/*": ["./boundedContext/presentation/components/*"],
      "@application/*": ["./boundedContext/application/*"]

      // We want to expose the exports of the buttons index file
      // "buttons": ["src/components/buttons/index"]
    }
  },
  // "include": ["app"],
  // "import/resolver": {
  //   "alias": [
  //     ["@/design-system/*", "./@design-system/*"],
  //     ["@/screens/*", "./boundedContext/presentation/screens/*"],
  //   ]
  // }
}
